# Murphy Agent environment

# Required: Slack token used by the supervisor itself.
SLACK_USER_TOKEN=xoxp-your-token-here

# Required for system messages such as maintenance summaries.
DEFAULT_CHANNEL_ID=C0YOUR_CHANNEL_ID

# Worker CLI used for regular task execution.
# WORKER_CMD="codex exec --yolo --ephemeral --skip-git-repo-check -"

# Developer-review CLI used during maintenance phase 1.
# DEV_REVIEW_CMD="claude -p --dangerously-skip-permissions --mcp-config src/config/claude_mcp.json"

# Optional Tribune review. Disabled by default in src/config/supervisor_loop.conf.
# TRIBUNE_MAX_REVIEW_ROUNDS=1

# Optional dashboard/static export.
# DASHBOARD_EXPORT_ENABLED=false
# DASHBOARD_EXPORT_DIR=dashboard-export
# DASHBOARD_GIT_PUSH=false

# Optional parallelism.
# MAX_CONCURRENT_WORKERS=1
# SESSION_MINUTES=360
