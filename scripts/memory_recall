#!/usr/bin/env python3
"""Search memory and reports with file/line citations."""

from __future__ import annotations

import argparse
import re
import shutil
import subprocess
import sys
from pathlib import Path
from typing import List, Tuple


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(
        description=(
            "Search `.agent/memory/memory.md`, `.agent/memory/daily/*.md`, and `reports/*.md` "
            "for a query and print path/line citations."
        )
    )
    parser.add_argument("query", help="Search query (ripgrep regex).")
    parser.add_argument(
        "-n",
        "--limit",
        type=int,
        default=20,
        help="Maximum number of matches to print (default: 20).",
    )
    parser.add_argument(
        "--path",
        action="append",
        default=[],
        help="Additional file or directory to include in search scope (repeatable).",
    )
    return parser.parse_args()


def build_scope(extra_paths: List[str]) -> List[str]:
    scope: List[str] = []

    memory_file = Path(".agent/memory/memory.md")
    if memory_file.exists():
        scope.append(str(memory_file))

    daily_dir = Path(".agent/memory/daily")
    if daily_dir.exists():
        scope.append(str(daily_dir))

    reports_dir = Path("reports")
    if reports_dir.exists():
        scope.append(str(reports_dir))

    for raw in extra_paths:
        path = Path(raw)
        if path.exists():
            scope.append(str(path))

    deduped: List[str] = []
    seen = set()
    for item in scope:
        if item in seen:
            continue
        seen.add(item)
        deduped.append(item)
    return deduped


def run_rg(query: str, scope: List[str]) -> Tuple[int, str, str]:
    cmd = [
        "rg",
        "--line-number",
        "--no-heading",
        "--color",
        "never",
        "--smart-case",
        query,
        *scope,
    ]
    proc = subprocess.run(cmd, capture_output=True, text=True, check=False)
    return proc.returncode, proc.stdout or "", proc.stderr or ""


def parse_matches(raw: str) -> List[Tuple[str, int, str]]:
    out: List[Tuple[str, int, str]] = []
    for line in raw.splitlines():
        parts = line.split(":", 2)
        if len(parts) != 3:
            continue
        path, line_no_s, snippet = parts
        if not re.match(r"^\d+$", line_no_s):
            continue
        out.append((path, int(line_no_s), snippet.strip()))
    return out


def main() -> int:
    args = parse_args()

    if shutil.which("rg") is None:
        print("error: `rg` is required but not found in PATH", file=sys.stderr)
        return 2

    scope = build_scope(args.path)
    if not scope:
        print("No searchable scope found. Expected one of: .agent/memory/memory.md, .agent/memory/daily/, reports/.")
        return 1

    rc, stdout, stderr = run_rg(args.query, scope)
    if rc not in {0, 1}:
        print("error: ripgrep failed", file=sys.stderr)
        if stderr.strip():
            print(stderr.strip(), file=sys.stderr)
        return 2

    matches = parse_matches(stdout)
    if not matches:
        print(f"Query: {args.query}")
        print("No matches.")
        return 0

    print(f"Query: {args.query}")
    print("Scope:")
    for item in scope:
        print(f"- {item}")
    print("Matches:")
    for idx, (path, line_no, snippet) in enumerate(matches[: max(1, args.limit)], start=1):
        print(f"{idx}. {path}:{line_no}")
        print(f"   {snippet}")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
