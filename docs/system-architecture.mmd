%%{init: {'theme': 'base', 'themeVariables': {'fontSize': '18px', 'lineColor': '#666'}, 'flowchart': {'rankSpacing': 50, 'nodeSpacing': 40, 'curve': 'basis', 'padding': 16}}}%%

graph TD
    Human(["🧑 Human"])
    Human -- "@mention" --> Slack(["💬 Slack"])
    Slack -- "results" --> Human

    Slack -- "poll" --> SV["🔄 Supervisor"]
    SV -- "spawn" --> Murphy
    SV -- "daily" --> Maint

    subgraph Murphy ["Murphy (AI Worker)"]
        direction TB
        Read["Read context & ACK"] --> Work["Research · Code · Experiment"]
        Work --> Report["Report & deliver PDF"]
    end

    Work -. "consult" .-> Athena
    Report -- "outcome" --> SV
    Murphy -- "save" --> State
    Murphy -. "messages" .-> Slack

    subgraph Athena ["🔮 Athena (ChatGPT Pro)"]
        Deep["Deep — proofs, derivations, PDFs"]
        Std["Standard — quick Q&A"]
    end

    subgraph State ["💾 Persistent State"]
        MemGoals["Memory & Goals"]
        Projects["Project Folders & Reports"]
    end

    subgraph Maint ["🔧 Maintenance"]
        direction LR
        Reflect["Reflect & tidy"] --> DevRev["Developer review & restart"]
    end

    SV -- "export" --> Dash["🌐 Dashboard"]

    %% Styles
    classDef human fill:#E8F5E9,stroke:#2E7D32,stroke-width:2px,color:#1B5E20
    classDef slack fill:#F3E5F5,stroke:#7B1FA2,stroke-width:2px,color:#4A148C
    classDef sv fill:#E3F2FD,stroke:#1565C0,stroke-width:2px,color:#0D47A1
    classDef worker fill:#FFF3E0,stroke:#E65100,stroke-width:1.5px,color:#BF360C
    classDef athena fill:#FCE4EC,stroke:#C62828,stroke-width:1.5px,color:#B71C1C
    classDef state fill:#ECEFF1,stroke:#546E7A,stroke-width:1px,color:#37474F
    classDef maint fill:#FFFDE7,stroke:#F57F17,stroke-width:1.5px,color:#E65100
    classDef dash fill:#E0F7FA,stroke:#00838F,stroke-width:1.5px,color:#006064

    class Human human
    class Slack slack
    class SV sv
    class Read,Work,Report worker
    class Deep,Std athena
    class MemGoals,Projects state
    class Reflect,DevRev maint
    class Dash dash
